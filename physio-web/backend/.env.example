# Database Configuration
# SQLite (default)
DATABASE_URL=sqlite:///./physio_monitoring.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost/physio_monitoring

# Security
SECRET_KEY=your-secret-key-here-change-in-production-please
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: External Services
# TTS_SERVICE=pyttsx3  # or gtts
# OPENAI_API_KEY=your-openai-key-here  # For advanced chatbot features
